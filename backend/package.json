{
  "name": "community-platform-backend",
  "version": "1.0.0",
  "description": "Backend for community content platform",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "db:update": "node scripts/syncDatabase.js",
    "db:sync": "node scripts/syncDatabase.js --sync",
    "db:normalize-moderation": "node scripts/normalizeModerationCases.js",
    "db:migrate": "node scripts/syncDatabase.js --sync && node scripts/normalizeModerationCases.js && node scripts/backfillUserSearchFields.js && node scripts/backfillContentSearchFields.js",
    "backfill:content-search": "node scripts/backfillContentSearchFields.js",
    "backfill:user-search": "node scripts/backfillUserSearchFields.js",
    "backfill:notification-comments": "node scripts/backfillNotificationCommentMetadata.js",
    "backfill:notification-content-status": "node scripts/backfillNotificationContentStatus.js",
    "redis:check": "node scripts/checkRedis.js",
    "test": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "file-type": "^22.0.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "lru-cache": "^11.3.0",
    "mongoose": "^8.0.0",
    "multer": "^2.1.1",
    "superagent": "^10.3.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "fast-check": "^3.15.0",
    "mongodb-memory-server": "^9.1.3",
    "supertest": "^7.2.2",
    "vitest": "^1.0.4"
  }
}
